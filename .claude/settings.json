{
  "permissions": {
    "allow": [
      "Bash(awk *)",
      "Bash(./gradlew *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(gh *)",
      "Bash(find *)",
      "Bash(ls *)",
      "Bash(dir *)",
      "Bash(java -jar *)",
      "Bash(javac *)",
      "Bash(jar *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "./gradlew spotlessApply -q" }
        ]
      }
    ]
  }
}